# ======================================================
# Пример .env для локального запуска / Docker
# Скопируйте файл в .env и заполните своими значениями.
# ======================================================

# --- Telegram ---
# Токен бота от @BotFather
BOT_TOKEN=123456789:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# --- BGBilling API ---
# Базовый URL BGBilling без завершающего /
BGBILLING_API_URL=https://billing.example.com

# BasicAuth для запросов в BGBilling
BGBILLING_USER=api_user
BGBILLING_PASSWORD=api_password

# Токен для авторизации входящих webhook-запросов от биллинга
BILLING_API_TOKEN=super_secret_token

# --- Webhook / aiohttp ---
# Публичный URL вебхука Telegram (если используется webhook-режим)
WEBHOOK_URL=https://bot.example.com

# Путь webhook Telegram
WEBHOOK_PATH=/webhook

# Хост и порт встроенного aiohttp-сервера для billing endpoints
# Для Docker: BILLING_WEBHOOK_HOST=0.0.0.0
BILLING_WEBHOOK_HOST=127.0.0.1

# Локальный порт встроенного aiohttp-сервера для billing endpoints
BILLING_WEBHOOK_PORT=8443

# --- Support / Roles ---
# chat_id аккаунта техподдержки
SUPPORT_CHAT_ID=123456789

# chat_id администраторов через запятую
ADMIN_CHAT_IDS=123456789,987654321

# --- Database ---
# SQLite-файл (в Docker обычно /app/data/bot.db)
DB_PATH=./data/bot.db

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE=bot.log

# --- Телефоны для кнопок ---
SUPPORT_PHONE=+79998887766
BILLING_PHONE=+78889997755

# --- Платежи ---
# service-code магазина в cKassa
PAYMENT_SHOP_ID=123-45678-9

# --- Security ---
# Ключ шифрования паролей (Fernet, urlsafe base64).
# Пример генерации:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PASSWORD_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# Окружение приложения: dev | stage | production
# В production бот не стартует без валидного PASSWORD_ENCRYPTION_KEY
APP_ENV=dev

# Таймзона контейнера/процесса (влияет на локальное время в логах и datetime.now())
TZ=Etc/UTC

# --- Docker entrypoint (опционально) ---
# true  -> на старте контейнера выполнится миграция plaintext-паролей
# false -> обычный запуск без миграции
RUN_PASSWORD_MIGRATION_ON_START=false
